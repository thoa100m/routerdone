# RouterDone environment example.
# Copy to .env for local use. Do not commit real secrets.

# Required for Docker/Dokploy.
JWT_SECRET=replace-with-openssl-rand-hex-32
INITIAL_PASSWORD=replace-with-a-long-admin-password
API_KEY_SECRET=replace-with-openssl-rand-hex-32
MACHINE_ID_SALT=replace-with-openssl-rand-hex-32

# Force the dashboard password to always come from INITIAL_PASSWORD on every
# request, ignoring any hash stored in the DB. Intended for Dokploy / Docker
# deployments where the operator wants .env to be the single source of truth
# for the admin password across redeploys (the default behavior writes the
# first successful login's password back to the DB, which then pins it).
# Default: false (legacy behavior — DB hash takes precedence once set).
PASSWORD_FROM_ENV=false

# Runtime.
PORT=20128
NODE_ENV=production
TZ=UTC
HOSTNAME=0.0.0.0
DATA_DIR=/app/data
NEXT_TELEMETRY_DISABLED=1

# Public URL of this instance.
BASE_URL=http://localhost:20128
NEXT_PUBLIC_BASE_URL=http://localhost:20128

# Optional cloud/tunnel endpoint. Leave blank unless you run one.
CLOUD_URL=
NEXT_PUBLIC_CLOUD_URL=
TUNNEL_WORKER_URL=

# Security and ops.
AUTH_COOKIE_SECURE=false
REQUIRE_API_KEY=false
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true

# Optional OAuth provider credentials.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_ID=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=

# Optional outbound proxy for provider calls.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
